---
interface Props {
  title: string;
  summary?: string;
  image?: string;
  tags?: string[];
  slug: string;
}

const { title, summary, image, tags = [], slug } = Astro.props;
---

<article class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden hover:border-primary-300 dark:hover:border-primary-700 transition-colors">
  {image && (
    <img
      src={image}
      alt=""
      class="w-full h-40 object-cover"
      loading="lazy"
    />
  )}
  <div class="p-5">
    <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 mb-2">
      {title}
    </h3>
    {summary && (
      <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-3 mb-3">
        {summary}
      </p>
    )}
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>
