---
import { siteConfig } from '../data/siteConfig';
---

<section id="contact" class="py-12">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Contact</h2>
  <div class="grid sm:grid-cols-2 gap-8">
    <div class="space-y-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-primary-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Email</div>
          <a href={`mailto:${siteConfig.social.email}`} class="text-gray-900 dark:text-white">
            {siteConfig.social.email}
          </a>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-primary-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <div>
          <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Address</div>
          <div class="text-gray-900 dark:text-white">{siteConfig.contact.address}</div>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-primary-500 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <div>
          <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Office</div>
          <div class="text-gray-900 dark:text-white">{siteConfig.contact.office}</div>
        </div>
      </div>
    </div>

    <div class="rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800">
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=8.765%2C50.808%2C8.775%2C50.812&layer=mapnik&marker=50.8102%2C8.7705"
        class="w-full h-64"
        loading="lazy"
        title="Office location"
      ></iframe>
    </div>
  </div>
</section>
