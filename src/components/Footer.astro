---
import SocialLinks from './SocialLinks.astro';
import { siteConfig } from '../data/siteConfig';
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Built with
        <a href="https://astro.build" class="hover:text-primary-600 dark:hover:text-primary-400">Astro</a>.
      </div>
      <SocialLinks size="sm" />
    </div>
  </div>
</footer>
